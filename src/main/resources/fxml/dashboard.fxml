<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.DashboardController"
            stylesheets="@../css/dashboard.css"
            styleClass="dashboard-root">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="22" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ImageView fitHeight="48" fitWidth="48" preserveRatio="true">
                    <Image url="@/images/ram.png"/>
                </ImageView>
                <VBox spacing="2">
                    <Label text="FSC VALET" styleClass="sidebar-brand"/>
                    <Label text="RAM Portal" styleClass="sidebar-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="10">
                <Button fx:id="navCheckInButton"
                        text="Make a Request"
                        onAction="#handleCheckIn"
                        styleClass="sidebar-button"/>

                <Button fx:id="navActiveVehiclesButton"
                        text="My Requests"
                        onAction="#handleActiveVehicles"
                        styleClass="sidebar-button"/>

                <Button text="Profile"
                        onAction="#handleProfile"
                        styleClass="sidebar-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="22" styleClass="dashboard-content">

                    <!-- TOP BAR -->
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <VBox spacing="3">
                            <Label fx:id="greetingLabel"
                                   text="WELCOME RAM!"
                                   styleClass="header-title"/>
                            <Label text="Focus on class while we focus on parking."
                                   styleClass="header-subtitle"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="userNameLabel" text="[NAME]" styleClass="top-brand"/>
                    </HBox>

                    <!-- FILTER CHIPS -->
                    <HBox spacing="10">
                        <Button text="Total Capacity" styleClass="chip-button chip-active"/>
                        <Button text="Available Spots" styleClass="chip-button"/>

                    </HBox>

                    <!-- HERO PANELS -->
                    <HBox spacing="18">
                        <VBox HBox.hgrow="ALWAYS" spacing="16" styleClass="main-panel">
                            <Label text="EVERYTHING IS ONLY ONE CLICK AWAY." styleClass="panel-title"/>

                            <HBox spacing="18" alignment="CENTER_LEFT">
                                <VBox spacing="8" HBox.hgrow="ALWAYS">


                                    <Label text="Make a valet request when you're arriving on campus, and track it from your dashboard."
                                           wrapText="true"
                                           styleClass="panel-subtext"/>

                                    <HBox spacing="12">
                                        <Button fx:id="requestValetButton"
                                                text="REQUEST VALET"
                                                onAction="#handleCheckIn"
                                                styleClass="primary-button"/>

                                        <Button fx:id="valetStatus"
                                                text="VALET STATUS"
                                                onAction="#handleActiveVehicles"
                                                styleClass="primary-button"/>

                                        <Button fx:id="viewAllButton"
                                                text="TRACKER"
                                                onAction="#handleViewAll"
                                                styleClass="outline-button"/>
                                    </HBox>
                                </VBox>


                            </HBox>
                        </VBox>


                    </HBox>

                    <!-- QUICK ACTIONS -->
                    <VBox spacing="14" styleClass="section-panel">
                        <Label text="Quick Actions" styleClass="panel-title"/>

                        <HBox spacing="16">
                            <StackPane HBox.hgrow="ALWAYS" styleClass="action-card" onMouseClicked="#handleCheckIn">
                                <VBox spacing="6">
                                    <Label text="Valet News" styleClass="action-title"/>
                                    <Label text="Keep up to date with FSC Valet news."
                                           wrapText="true"
                                           styleClass="action-subtitle"/>
                                </VBox>
                            </StackPane>

                            <StackPane HBox.hgrow="ALWAYS" styleClass="action-card" onMouseClicked="#handleActiveVehicles">
                                <VBox spacing="6">
                                    <Label text="Survey" styleClass="action-title"/>
                                    <Label text="We would love to hear from you."
                                           wrapText="true"
                                           styleClass="action-subtitle"/>
                                </VBox>
                            </StackPane>

                            <StackPane HBox.hgrow="ALWAYS" styleClass="action-card" onMouseClicked="#handleViewAll">
                                <VBox spacing="6">
                                    <Label text="Contact us" styleClass="action-title"/>
                                    <Label text="(631)-909-3299."
                                           wrapText="true"
                                           styleClass="action-subtitle"/>
                                </VBox>
                            </StackPane>
                        </HBox>
                    </VBox>

                    <!-- RECENT REQUESTS -->
                    <VBox spacing="14" styleClass="section-panel">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Recent Requests" styleClass="panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="View All" onAction="#handleViewAll" styleClass="outline-button"/>
                        </HBox>

                        <VBox fx:id="emptyState" alignment="CENTER" spacing="12" styleClass="empty-state-box">
                            <Label text="No recent requests yet" styleClass="empty-state-title"/>
                            <Label text="Once you begin using FSC Valet, your recent activity will appear here."
                                   wrapText="true"
                                   styleClass="panel-subtext"/>
                            <Button fx:id="checkInFirstButton"
                                    text="MAKE FIRST REQUEST"
                                    onAction="#handleCheckIn"
                                    styleClass="primary-button"/>
                        </VBox>

                        <FlowPane fx:id="vehicleListContainer"
                                  hgap="16"
                                  vgap="16"
                                  visible="false"
                                  managed="false"/>
                    </VBox>

                    <!-- FOOTER MESSAGE -->
                    <HBox alignment="CENTER">
                        <Label text="No need to worry, your vehicle is safe with FSC Valet!"
                               styleClass="footer-text"/>
                    </HBox>

                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>