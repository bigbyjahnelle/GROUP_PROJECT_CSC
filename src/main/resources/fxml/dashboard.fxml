<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.DashboardController"
            stylesheets="@../css/dashboard.css"
            styleClass="dashboard-root">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="dashboard-header" spacing="12">
            <VBox spacing="4">
                <Label fx:id="greetingLabel"
                       text="Good Evening [NAME]"
                       styleClass="dashboard-greeting"/>
                <Label text="Welcome back to FSC Valet"
                       styleClass="dashboard-subtext"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <ImageView fitHeight="42" fitWidth="42" preserveRatio="true">
                <Image url="@/images/ram.png"/>
            </ImageView>
        </HBox>
    </top>

    <center>
        <VBox spacing="22" styleClass="dashboard-content">

            <!-- STATUS CARD -->
            <VBox alignment="CENTER" spacing="14" styleClass="status-card">
                <Label fx:id="requestStatusLabel"
                       text="No Active Valet Requests"
                       styleClass="status-text"/>

                <Label text="Tap below to request valet service"
                       styleClass="dashboard-subtext"/>
            </VBox>

            <!-- STATS -->
            <HBox spacing="14">
                <VBox HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" styleClass="stat-card">
                    <Label text="Available Spots" styleClass="stat-title"/>
                    <Label fx:id="availableSpotsLabel" text="50" styleClass="stat-value"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" styleClass="stat-card">
                    <Label text="Total Capacity" styleClass="stat-title"/>
                    <Label fx:id="totalCapacityLabel" text="50" styleClass="stat-value"/>
                </VBox>
            </HBox>

            <!-- MAIN BUTTON -->
            <Button fx:id="requestValetButton"
                    text="REQUEST VALET"
                    onAction="#handleCheckIn"
                    styleClass="gold-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- HISTORY -->
            <VBox spacing="16">
                <HBox alignment="CENTER" spacing="10">
                    <Region HBox.hgrow="ALWAYS" styleClass="history-line"/>
                    <Label text="History" styleClass="history-title"/>
                    <Region HBox.hgrow="ALWAYS" styleClass="history-line"/>
                </HBox>

                <VBox fx:id="emptyState"
                      alignment="CENTER"
                      spacing="8"
                      styleClass="history-empty-box">
                    <Label text="No valet history yet"
                           styleClass="history-empty-text"/>
                    <Label text="Your previous requests will show here."
                           styleClass="dashboard-subtext"/>
                </VBox>

                <VBox fx:id="vehicleListContainer"
                      spacing="10"
                      visible="false"
                      managed="false"/>

                <Button fx:id="viewAllButton"
                        text="VIEW HISTORY"
                        onAction="#handleViewAll"
                        styleClass="ghost-button"/>
            </VBox>

            <padding>
                <Insets top="6" right="18" bottom="18" left="18"/>
            </padding>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="12" styleClass="bottom-nav">
            <Button text="Home" styleClass="bottom-nav-button bottom-nav-active"/>
            <Label text="|" styleClass="nav-divider"/>
            <Button text="Request Valet"
                    onAction="#handleCheckIn"
                    styleClass="bottom-nav-button"/>
            <Label text="|" styleClass="nav-divider"/>
            <Button text="Profile"
                    onAction="#handleActiveVehicles"
                    styleClass="bottom-nav-button"/>
        </HBox>
    </bottom>

</BorderPane>