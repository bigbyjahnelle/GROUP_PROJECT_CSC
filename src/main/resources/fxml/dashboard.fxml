<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.DashboardController"
            stylesheets="@../css/dashboard.css"
            styleClass="dashboard-root">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="22" styleClass="sidebar">
            <HBox alignment="TOP_LEFT" spacing="12" styleClass="sidebar-brand-row">
                <ImageView fitHeight="44" fitWidth="44" preserveRatio="true">
                    <Image url="@/images/ram.png"/>
                </ImageView>
                <VBox spacing="2">
                    <Label text="FSC VALET" styleClass="sidebar-brand"/>
                    <Label text="RAM Portal" styleClass="sidebar-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="10">
                <Button fx:id="navCheckInButton"
                        text="Make a Request"
                        onAction="#handleCheckIn"
                        styleClass="sidebar-button"/>

                <Button fx:id="navActiveVehiclesButton"
                        text="My Requests"
                        onAction="#handleActiveVehicles"
                        styleClass="sidebar-button"/>

                <Button text="Profile"
                        onAction="#handleProfile"
                        styleClass="sidebar-button"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="themeToggleButton"
                    text="☾"
                    onAction="#handleThemeToggle"
                    styleClass="theme-toggle"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="20" styleClass="dashboard-content">

                    <!-- TOP BAR -->
                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="userNameLabel" text="" styleClass="top-brand"/>
                    </HBox>

                    <!-- 4 STAT CARDS -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Active Vehicles" styleClass="stat-card-label"/>
                                    <Label fx:id="activeVehiclesLabel" text="0" styleClass="stat-card-value"/>
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-blue">
                                    <Label text="🚗" style="-fx-font-size: 22px;"/>
                                </StackPane>
                            </HBox>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Available Spots" styleClass="stat-card-label"/>
                                    <Label fx:id="availableSpotsLabel" text="50" styleClass="stat-card-value"/>
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-green">
                                    <Label text="P" styleClass="stat-icon-letter stat-icon-letter-green"/>
                                </StackPane>
                            </HBox>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Total Capacity" styleClass="stat-card-label"/>
                                    <Label fx:id="totalCapacityLabel" text="50" styleClass="stat-card-value"/>
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-purple">
                                    <Label text="↗" styleClass="stat-icon-letter stat-icon-letter-purple"/>
                                </StackPane>
                            </HBox>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Today's Check-ins" styleClass="stat-card-label"/>
                                    <Label fx:id="todayCheckinsLabel" text="0" styleClass="stat-card-value"/>
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-orange">
                                    <Label text="🕐" style="-fx-font-size: 22px;"/>
                                </StackPane>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- PARKING STATUS -->
                    <VBox spacing="12" styleClass="section-panel">
                        <Label text="Parking Status" styleClass="panel-title"/>

                        <HBox alignment="CENTER_LEFT">
                            <Label text="Occupancy Rate" styleClass="stat-card-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="occupancyPercentLabel" text="0%" styleClass="occupancy-percent"/>
                        </HBox>

                        <ProgressBar fx:id="occupancyBar" progress="0" maxWidth="Infinity" styleClass="dashboard-progress-bar"/>

                        <HBox>
                            <Label fx:id="parkedCountLabel" text="0 Parked" styleClass="stat-card-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="availableCountLabel" text="50 Available" styleClass="stat-card-label"/>
                        </HBox>
                    </VBox>

                    <!-- RECENT CHECK-INS -->
                    <VBox spacing="14" styleClass="section-panel">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Recent Check-ins" styleClass="panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="viewAllButton" text="View All" onAction="#handleViewAll" styleClass="outline-button"/>
                        </HBox>

                        <VBox fx:id="emptyState" alignment="CENTER" spacing="12" styleClass="empty-state-box">
                            <Label text="🚗" styleClass="empty-car-icon"/>
                            <Label text="No vehicles parked yet" styleClass="empty-state-title"/>
                            <Button fx:id="checkInFirstButton"
                                    text="Check In First Vehicle"
                                    onAction="#handleCheckIn"
                                    styleClass="primary-button"/>
                        </VBox>

                        <FlowPane fx:id="vehicleListContainer"
                                  hgap="16"
                                  vgap="16"
                                  visible="false"
                                  managed="false"/>
                    </VBox>

                    <!-- BOTTOM ACTION CARDS -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" styleClass="action-card-dashed" onMouseClicked="#handleCheckIn">
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <StackPane styleClass="action-icon action-icon-blue">
                                    <Label text="+" styleClass="action-icon-plus"/>
                                </StackPane>
                                <VBox spacing="4">
                                    <Label text="Check In Vehicle" styleClass="action-title"/>
                                    <Label text="Add new vehicle to parking" styleClass="action-subtitle"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" styleClass="action-card-dashed" onMouseClicked="#handleActiveVehicles">
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <StackPane styleClass="action-icon action-icon-green">
                                    <Label text="&#8801;" styleClass="action-icon-menu"/>
                                </StackPane>
                                <VBox spacing="4">
                                    <Label text="View Active Vehicles" styleClass="action-title"/>
                                    <Label text="Manage parked vehicles" styleClass="action-subtitle"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
