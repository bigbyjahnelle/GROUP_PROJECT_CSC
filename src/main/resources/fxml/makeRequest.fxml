<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.MakeRequestController"
            stylesheets="@../css/makeRequest.css">

    <!-- HEADER -->
    <top>
        <HBox styleClass="mr-header">
            <Button text="← Back" styleClass="back-btn" onAction="#handleBack"/>
            <Label text="Make a Valet Request" styleClass="mr-title"/>
        </HBox>
    </top>

    <!-- FORM -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="mr-scroll" hbarPolicy="NEVER">
            <StackPane>
                <padding>
                    <Insets top="40" right="24" bottom="40" left="24"/>
                </padding>

                <VBox styleClass="form-card">
                    <padding>
                        <Insets top="36" right="40" bottom="36" left="40"/>
                    </padding>

                    <!-- SECTION HEADER -->
                    <Label text="Car Details" styleClass="section-title"/>
                    <Region styleClass="section-divider" maxWidth="Infinity"/>

                    <!-- MAKE -->
                    <VBox spacing="4">
                        <Label text="MAKE" styleClass="field-label"/>
                        <HBox styleClass="input-box">
                            <TextField fx:id="makeField" promptText="e.g. Toyota"
                                       styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- MODEL -->
                    <VBox spacing="4">
                        <Label text="MODEL" styleClass="field-label"/>
                        <HBox styleClass="input-box">
                            <TextField fx:id="modelField" promptText="e.g. Camry"
                                       styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- YEAR -->
                    <VBox spacing="4">
                        <Label text="YEAR" styleClass="field-label"/>
                        <HBox styleClass="input-box">
                            <TextField fx:id="yearField" promptText="e.g. 2020"
                                       styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- COLOR -->
                    <VBox spacing="4">
                        <Label text="COLOR" styleClass="field-label"/>
                        <HBox styleClass="input-box">
                            <TextField fx:id="colorField" promptText="e.g. Silver"
                                       styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- LICENSE PLATE -->
                    <VBox spacing="4">
                        <Label text="LICENSE PLATE" styleClass="field-label"/>
                        <HBox styleClass="input-box">
                            <TextField fx:id="licensePlateField" promptText="e.g. ABC-1234"
                                       styleClass="input-field" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- STATUS -->
                    <Label fx:id="statusLabel" text="" styleClass="status-label"/>

                    <!-- SUBMIT -->
                    <Button text="Submit Request" styleClass="submit-btn"
                            onAction="#handleSubmit" maxWidth="Infinity"/>
                </VBox>
            </StackPane>
        </ScrollPane>
    </center>
</BorderPane>
