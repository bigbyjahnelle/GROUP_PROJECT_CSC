<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.controller.LoginController"
      style="-fx-padding: 40;">

    <Label text="Valet Parking System" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="250"/>

    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250"/>

    <Button fx:id="loginButton" text="Login" minWidth="100"/>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill: red;"/>

</VBox>