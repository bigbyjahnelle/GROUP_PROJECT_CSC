<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@/css/login.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="client.controller.CreateAccountController">

    <VBox alignment="CENTER" spacing="20">

        <Label text="FSC VALET" styleClass="title">
            <font>
                <Font name="Montserrat" size="37"/>
            </font>
        </Label>

        <ImageView fitHeight="200" fitWidth="200" styleClass="logo">
            <Image url="@/images/ram.png"/>
        </ImageView>

        <Label text="SIGN UP" styleClass="subtext"/>

        <HBox prefHeight="50" prefWidth="300"
              minWidth="300" maxWidth="300"
              spacing="10"
              alignment="CENTER"
              styleClass="input-box">

            <ImageView fitHeight="18" fitWidth="18">
                <Image url="@/images/user_icon.png"/>
            </ImageView>

            <!-- FIRST NAME -->
            <TextField fx:id="firstNameField"
                       promptText="FIRSTNAME"
                       styleClass="input-field"
                       HBox.hgrow="ALWAYS"/>

            <Pane styleClass="name-divider"/>

            <!-- LAST NAME -->
            <TextField fx:id="lastNameField"
                       promptText="LASTNAME"
                       styleClass="input-field"
                       HBox.hgrow="ALWAYS"/>

        </HBox>


        <HBox prefHeight="50" prefWidth="300"
              minWidth="300" maxWidth="300"
              spacing="10"
              alignment="CENTER_LEFT"
              styleClass="input-box">

            <ImageView fitHeight="18" fitWidth="18">
                <Image url="@/images/mail_icon.png"/>
            </ImageView>

            <TextField fx:id="emailField"
                       promptText="EMAIL"
                       styleClass="input-field"
                       prefWidth="240"/>
        </HBox>

        <HBox prefHeight="50" prefWidth="300"
              minWidth="300" maxWidth="300"
              spacing="10"
              alignment="CENTER_LEFT"
              styleClass="input-box">

            <ImageView fitHeight="18" fitWidth="18">
                <Image url="@/images/lock_icon.png"/>
            </ImageView>

            <PasswordField fx:id="passwordField"
                           promptText="PASSWORD"
                           styleClass="input-field"
                           prefWidth="240"/>
        </HBox>

        <HBox prefHeight="50" prefWidth="300"
              minWidth="300" maxWidth="300"
              spacing="10"
              alignment="CENTER_LEFT"
              styleClass="input-box">

            <ImageView fitHeight="18" fitWidth="18">
                <Image url="@/images/lock_icon.png"/>
            </ImageView>

            <PasswordField fx:id="confirmPasswordField"
                           promptText="CONFIRM PASSWORD"
                           styleClass="input-field"
                           prefWidth="240"/>
        </HBox>

        <Button fx:id="createAccountButton"
                text="CREATE ACCOUNT"
                prefWidth="300"
                prefHeight="50"
                styleClass="login-btn"/>

        <HBox alignment="CENTER" spacing="3">
            <Label text="I agree to the" styleClass="subtext"/>
            <Label text="terms and privacy"
                   style="-fx-text-fill: #F5DA82;"/>
        </HBox>

        <Label fx:id="statusLabel" style="-fx-text-fill: red;"/>

        <HBox alignment="CENTER" spacing="-5">
            <Label text="Already have an account?" styleClass="subtext"/>

            <Button fx:id="backToLoginButton"
                    text="Log in"
                    styleClass="signup-btn"/>
        </HBox>

    </VBox>

</StackPane>